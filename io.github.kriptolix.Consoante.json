{
    "id" : "io.github.kriptolix.Consoante",
    "runtime" : "org.gnome.Platform",
    "runtime-version" : "50",
    "sdk" : "org.gnome.Sdk",
    "command" : "consoante",
    "add-extensions": {
    "org.freedesktop.Platform.ffmpeg-full": {
      "version": "24.08",
      "directory": "lib/ffmpeg",
      "add-ld-path": "."
    }
  },
  "cleanup-commands": [
    "mkdir -p ${FLATPAK_DEST}/lib/ffmpeg"
  ],
    "finish-args" : [
        "--share=network",
        "--share=ipc",
        "--socket=fallback-x11",
        "--device=dri",
        "--socket=wayland"
    ],
    "cleanup" : [
        "/include",
        "/lib/pkgconfig",
        "/man",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "/share/pkgconfig",
        "*.la",
        "*.a"
    ],    
    "modules" : [
        "requirements/python3-mutagen.json",
        "requirements/python3-pybind11.json",
        "requirements/python3-meson-python.json",
        "requirements/python3-pillow.json",
        "requirements/python3-numpy.json",
        "requirements/python3-pythran.json",
        "requirements/python3-scipy.json",
        "requirements/python3-soundfile.json",
        "requirements/python3-librosa.json",
        {
            "name" : "consoante",
            "builddir" : true,
            "buildsystem" : "meson",
            "sources" : [
                {
                    "type" : "git",
                    "url" : "file:///home/k/Projetos"
                }
            ]
        }
    ]
}
