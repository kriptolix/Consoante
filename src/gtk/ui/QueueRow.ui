<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <template class="QueueRow" parent="AdwActionRow">
    <property name="title">Metal Contra as Nuvens</property>
    <property name="subtitle">MTV ao Vivo</property>
    <child type="prefix">
      <object class="GtkImage">
        <property name="icon-name">accessories-calculator-symbolic</property>
        <property name="pixel-size">32</property>
      </object>
    </child>
    <child type="suffix">
      <object class="GtkImage">
        <property name="icon-name">audio-only-symbolic</property>
        <property name="pixel-size">16</property>
      </object>
    </child>
  </template>
</interface>