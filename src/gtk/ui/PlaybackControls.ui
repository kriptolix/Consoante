<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <template class="PlaybackControls" parent="GtkBox">
    <property name="orientation">1</property>
    <property name="spacing">6</property>
    <property name="width-request">256</property>
    <child>
      <object class="GtkBox">
        <property name="margin-start">10</property>
        <property name="margin-end">10</property>
        <property name="spacing">1</property>
        <property name="halign">3</property>
        <property name="hexpand">true</property>
        <child>
          <object class="GtkLabel">
            <property name="label">00:00</property>
          </object>
        </child>
        <child>
          <object class="GtkScale" id="one">
            <property name="orientation">0</property>
            <property name="width-request">190</property>
            <property name="adjustment">
              <object class="GtkAdjustment">
                <property name="lower">0</property>
                <property name="upper">100</property>
                <property name="value">30</property>
              </object>
            </property>
          </object>
        </child>
        <child>
          <object class="GtkLabel">
            <property name="label">00:00</property>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="GtkBox" id="controls_box">
        <property name="spacing">24</property>
        <property name="halign">3</property>
        <property name="hexpand">true</property>
        <child>
          <object class="GtkToggleButton" id="shuffle_button">
            <property name="icon-name">media-playlist-shuffle-symbolic</property>
            <property name="action-name">queue.shuffle</property>
            <property name="valign">3</property>
            <property name="tooltip-text" translatable="yes">Shuffle the Playlist</property>
            <accessibility>
              <property name="label" translatable="yes">Shuffle</property>
            </accessibility>
            <style>
              <class name="circular"/>
            </style>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="previous_button">
            <property name="icon-name">media-skip-backward-symbolic</property>
            <property name="action-name">win.previous</property>
            <property name="valign">3</property>
            <property name="tooltip-text" translatable="yes">Play the Previous Song</property>
            <style>
              <class name="circular"/>
            </style>
            <accessibility>
              <property name="label" translatable="yes">Skip backwards</property>
            </accessibility>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="play_button">
            <property name="icon-name">media-playback-start-symbolic</property>
            <property name="action-name">win.play</property>
            <property name="valign">3</property>
            <property name="tooltip-text" translatable="yes">Toggle Play</property>
            <style>
              <class name="circular"/>
              <class name="large"/>
            </style>
            <accessibility>
              <property name="label" translatable="yes">Toggle play</property>
            </accessibility>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="next_button">
            <property name="icon-name">media-skip-forward-symbolic</property>
            <property name="action-name">win.next</property>
            <property name="valign">3</property>
            <property name="tooltip-text" translatable="yes">Play the Next Song</property>
            <style>
              <class name="circular"/>
            </style>
            <accessibility>
              <property name="label" translatable="yes">Skip forward</property>
            </accessibility>
          </object>
        </child>
        <child>
          <object class="GtkScaleButton" id="repeat_button">
            <property name="valign">3</property>
            <property name="tooltip-text" translatable="yes">Enable Repeat</property>
            <style>
              <class name="circular"/>
            </style>
            <accessibility>
              <property name="label" translatable="yes">Repeat</property>
            </accessibility>
          </object>
        </child>
      </object>
    </child>
  </template>
</interface>